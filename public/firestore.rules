rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Products — anyone reads, auth writes
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Categories
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders — anyone creates, auth reads/manages
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Users — own profile read/write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Wishlists — own wishlist
    match /wishlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Points — own points
    match /points/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }
    match /points_history/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Testimonials
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Product Reviews
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Visitor tracking
    match /visitors/{id} {
      allow read, write: if true;
    }

    // Coupons
    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Referrals
    match /referrals/{id} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Animated Banners
    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Owner posts (announcements/stories)
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Community posts (customers upload photos/videos)
    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Reports (abuse reports)
    match /reports/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // Blocked users/devices
    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
