rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════╗
    // ║          ZAHRAA STUDIO FIRESTORE RULES       ║
    // ║  آمن 100% — أضفها في Firebase Console       ║
    // ╚══════════════════════════════════════════════╝

    // ──────────────────────────────────────────────
    // PRODUCTS: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // CATEGORIES: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // SETTINGS: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // ORDERS: أي أحد ينشئ | الأدمن يقرأ ويعدّل ويحذف
    // ──────────────────────────────────────────────
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // USERS: المسجّل يقرأ أي مستخدم | الأدمن يكتب على أي مستخدم
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // WISHLISTS: المستخدم يقرأ ويكتب مفضّلته فقط
    // ──────────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────
    // POINTS & HISTORY: المسجّل يقرأ | أي أحد يكتب (لمنح النقاط)
    // ──────────────────────────────────────────────
    match /points/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /points_history/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // TESTIMONIALS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    // ──────────────────────────────────────────────
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // PRODUCT REVIEWS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    // ──────────────────────────────────────────────
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // VISITORS: الكل يقرأ ويكتب (تتبّع الزوار)
    // ──────────────────────────────────────────────
    match /visitors/{id} {
      allow read, write: if true;
    }

    // ──────────────────────────────────────────────
    // COUPONS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // REFERRALS: المسجّل يقرأ | أي أحد ينشئ
    // ──────────────────────────────────────────────
    match /referrals/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BANNERS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // POSTS (إعلانات وأخبار): الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // COMMUNITY POSTS: الكل يقرأ وينشئ
    //   الصاحب يحذف/يخفي مشاركته | الأدمن يتحكم في الكل
    // ──────────────────────────────────────────────
    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      // الأدمن يعدّل أي منشور — الصاحب يخفي منشوره فقط
      allow update: if request.auth != null
                    || (request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['isHidden', 'hiddenByOwner', 'reportCount']));
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // REPORTS (بلاغات): الكل ينشئ | الأدمن يقرأ ويعدّل ويحذف
    // ──────────────────────────────────────────────
    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BLOCKED USERS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // ADS (إعلانات منبثقة): الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /ads/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // PUSH TOKENS: الكل ينشئ/يعدّل (تسجيل الجهاز)
    //              الأدمن يقرأ كل التوكنات
    // ──────────────────────────────────────────────
    match /push_tokens/{id} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // NOTIFICATIONS LOG: الأدمن فقط
    // ──────────────────────────────────────────────
    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }


    // ──────────────────────────────────────────────
    // SUPPORT CHATS: الكل ينشئ ويكتب في محادثته | الأدمن يقرأ ويرد
    // ──────────────────────────────────────────────
    match /support_chats/{chatId} {
      allow read: if request.auth != null
                  || request.resource == null
                  || resource == null
                  || resource.data.deviceId == chatId;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }


    // ──────────────────────────────────────────────
    // ABANDONED CARTS: العميل يحفظ/يقرأ/يحذف سلته بالـ deviceId
    // ──────────────────────────────────────────────
    match /abandoned_carts/{deviceId} {
      allow read, create, update, delete: if true;
    }

    // ──────────────────────────────────────────────
    // أي مجموعة أخرى: محظور تماماً (أمان افتراضي)
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
