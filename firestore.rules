rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    //  ZAHRAA STUDIO — Firestore Security Rules (Round 2)
    //  يشمل: pos_customers + orders update للعميل (إلغاء)
    // ════════════════════════════════════════════════════════

    // ── PRODUCTS ──────────────────────────────────────────
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── CLIENT PREVIEWS ───────────────────────────────────
    match /client_previews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── PREVIEW COMMENTS ──────────────────────────────────
    match /preview_comments/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── CATEGORIES ────────────────────────────────────────
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── SETTINGS ──────────────────────────────────────────
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── ORDERS ────────────────────────────────────────────
    // أي زائر ينشئ | العميل يقرأ ويعدّل طلباته | الأدمن يتحكم في كل شيء
    match /orders/{id} {
      allow create: if true;
      allow read: if request.auth != null
                  || (resource != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null
                    || (request.auth != null
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','cancelledAt','cancelledBy','cancellationNote']));
      allow delete: if request.auth != null;
    }

    // ── POS INVOICES ──────────────────────────────────────
    match /pos_invoices/{id} {
      allow read, write: if request.auth != null;
    }

    // ── POS CUSTOMERS (كاشير — سجل العملاء) ──────────────
    match /pos_customers/{id} {
      allow read, write: if request.auth != null;
    }

    // ── USERS ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── WISHLISTS ─────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── POINTS ────────────────────────────────────────────
    match /points/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /points_history/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── TESTIMONIALS ──────────────────────────────────────
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── PRODUCT REVIEWS ───────────────────────────────────
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── VISITORS ──────────────────────────────────────────
    match /visitors/{id} {
      allow read, write: if true;
    }

    // ── COUPONS ───────────────────────────────────────────
    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── REFERRALS ─────────────────────────────────────────
    match /referrals/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /referral_records/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ── BANNERS ───────────────────────────────────────────
    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── POSTS ─────────────────────────────────────────────
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── COMMUNITY POSTS ───────────────────────────────────
    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null
                    || (request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['isHidden', 'hiddenByOwner', 'reportCount']));
      allow delete: if request.auth != null;
    }

    // ── REPORTS ───────────────────────────────────────────
    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── BLOCKED / BANNED USERS ────────────────────────────
    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /banned_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ban_access_log/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // ── DELIVERY AGENTS ───────────────────────────────────
    match /delivery_agents/{id} {
      allow read, write: if request.auth != null;
    }

    // ── ADS ───────────────────────────────────────────────
    match /ads/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── PUSH TOKENS ───────────────────────────────────────
    match /push_tokens/{id} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ── NOTIFICATIONS ─────────────────────────────────────
    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    // ── SUPPORT CHATS ─────────────────────────────────────
    match /support_chats/{chatId} {
      allow read: if request.auth != null
                  || resource == null
                  || resource.data.deviceId == chatId;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ── ABANDONED CARTS ───────────────────────────────────
    match /abandoned_carts/{deviceId} {
      allow read, create, update, delete: if true;
    }

    // ── DEFAULT: deny all ─────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
