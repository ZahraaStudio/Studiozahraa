rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════╗
    // ║   ZAHRAA STUDIO — FIRESTORE RULES v3        ║
    // ║   شامل: مندوبين، حظر، فواتير POS، إحالات   ║
    // ╚══════════════════════════════════════════════╝

    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /client_previews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /preview_comments/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // POS فواتير الكاشير — الأدمن فقط
    match /pos_invoices/{id} {
      allow read, write: if request.auth != null;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /wishlists/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    match /points/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /points_history/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /visitors/{id} {
      allow read, write: if true;
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /referrals/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // سجل الإحالات — أي شخص يضيف
    match /referral_records/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null
                    || (request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['isHidden', 'hiddenByOwner', 'reportCount']));
      allow delete: if request.auth != null;
    }

    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ══════════════════════════════════
    // نظام الحظر الجديد
    // الكل يقرأ (لفحص حظر الجهاز عند تحميل الموقع)
    // الأدمن فقط يكتب
    // ══════════════════════════════════
    match /banned_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // سجل محاولات الوصول المحظورة
    // أي شخص يسجّل (حتى المحظور) | الأدمن يقرأ ويحذف
    match /ban_access_log/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // ══════════════════════════════════
    // المندوبين — الأدمن فقط
    // ══════════════════════════════════
    match /delivery_agents/{id} {
      allow read, write: if request.auth != null;
    }

    match /ads/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /push_tokens/{id} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /support_chats/{chatId} {
      allow read: if request.auth != null
                  || request.resource == null
                  || resource == null
                  || resource.data.deviceId == chatId;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    match /abandoned_carts/{deviceId} {
      allow read, create, update, delete: if true;
    }

    // أي مجموعة أخرى: محظور تماماً
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
