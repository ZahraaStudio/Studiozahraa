rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════╗
    // ║          ZAHRAA STUDIO FIRESTORE RULES       ║
    // ║  آمن 100% — أضفها في Firebase Console       ║
    // ╚══════════════════════════════════════════════╝

    // PRODUCTS: الكل يقرأ | الأدمن فقط يكتب
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // CATEGORIES: الكل يقرأ | الأدمن فقط يكتب
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // SETTINGS: الكل يقرأ | الأدمن فقط يكتب
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ORDERS: أي أحد ينشئ | الأدمن يقرأ ويعدّل ويحذف
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // USERS: المسجّل يقرأ | الأدمن يكتب
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // WISHLISTS: المستخدم يقرأ ويكتب مفضّلته فقط
    match /wishlists/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // POINTS
    match /points/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /points_history/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // TESTIMONIALS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // PRODUCT REVIEWS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // VISITORS: تتبّع الزوار
    match /visitors/{id} {
      allow read, write: if true;
    }

    // COUPONS: الكل يقرأ | الأدمن يكتب
    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // REFERRALS
    match /referrals/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // BANNERS: الكل يقرأ | الأدمن يكتب
    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // POSTS
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // COMMUNITY POSTS
    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null
                    || (request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['isHidden', 'hiddenByOwner', 'reportCount']));
      allow delete: if request.auth != null;
    }

    // REPORTS
    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // BLOCKED USERS
    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ADS
    match /ads/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // PUSH TOKENS: الكل يسجّل جهازه | الأدمن يقرأ الكل ويحذف القديم
    match /push_tokens/{id} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // NOTIFICATIONS LOG
    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    // ✅ جديد — ABANDONED CARTS: كل عميل يحفظ ويقرأ سلته بالـ deviceId
    // الأدمن يقرأ الكل ويحذف
    match /abandoned_carts/{deviceId} {
      allow create, update: if true;
      allow read: if request.auth != null || true; // العميل يقرأ سلته
      allow delete: if true; // يُحذف تلقائياً بعد الطلب
    }

    // SUPPORT CHATS
    match /support_chats/{chatId} {
      allow read: if request.auth != null
                  || resource == null
                  || resource.data.deviceId == chatId;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // أي مجموعة أخرى: محظور تماماً
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
