rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ╔══════════════════════════════════════════════╗
    // ║          ZAHRAA STUDIO FIRESTORE RULES       ║
    // ║  نسخة مطورة — تشمل ألبومات معاينة العملاء    ║
    // ╚══════════════════════════════════════════════╝

    // ──────────────────────────────────────────────
    // PRODUCTS: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // CLIENT PREVIEWS (ألبومات العملاء):
    // الكل يقرأ (للمعاينة بالباسورد) | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /client_previews/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // PREVIEW COMMENTS (تعليقات الصور):
    // الكل ينشئ (العميل) | الأدمن يقرأ ويعدّل ويحذف
    // ──────────────────────────────────────────────
    match /preview_comments/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // CATEGORIES: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // SETTINGS: الكل يقرأ | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /settings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // ORDERS: أي أحد ينشئ | الأدمن يقرأ ويعدّل ويحذف
    // ──────────────────────────────────────────────
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // POS INVOICES (فواتير الكاشير):
    // القراءة: الكل (صفحة حالة الطلب للعميل تقرأ بدون auth)
    // الكتابة: الأدمن فقط
    // ──────────────────────────────────────────────
    match /pos_invoices/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // INVOICES (فواتير العملاء): العميل يقرأ فاتورته | الأدمن يقرأ ويكتب
    // ──────────────────────────────────────────────
    match /invoices/{id} {
      allow read: if request.auth != null
                  || request.resource.data.customerId == request.auth.uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // INVOICE IMAGES (صور الفواتير من Cloudinary): العميل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /invoice_images/{id} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // USERS: المسجّل يقرأ أي مستخدم | الأدمن يكتب على أي مستخدم
    // ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // WISHLISTS: المستخدم يقرأ ويكتب مفضّلته فقط
    // ──────────────────────────────────────────────
    match /wishlists/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ──────────────────────────────────────────────
    // POINTS & HISTORY: المسجّل يقرأ | أي أحد يكتب (لمنح النقاط)
    // ──────────────────────────────────────────────
    match /points/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /points_history/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // TESTIMONIALS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    // ──────────────────────────────────────────────
    match /testimonials/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // PRODUCT REVIEWS: الكل يقرأ وينشئ | الأدمن يعدّل ويحذف
    // ──────────────────────────────────────────────
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // VISITORS: الكل يقرأ ويكتب (تتبّع الزوار)
    // ──────────────────────────────────────────────
    match /visitors/{id} {
      allow read, write: if true;
    }

    // ──────────────────────────────────────────────
    // COUPONS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /coupons/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /coupon_usage/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // REFERRALS & REFERRAL RECORDS: المسجّل يقرأ | أي أحد ينشئ
    // ──────────────────────────────────────────────
    match /referrals/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    match /referral_records/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BANNERS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /banners/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // POSTS (إعلانات وأخبار): الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /posts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // COMMUNITY POSTS: الكل يقرأ وينشئ
    //   الصاحب يحذف/يخفي مشاركته | الأدمن يتحكم في الكل
    // ──────────────────────────────────────────────
    match /community_posts/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if request.auth != null
                    || (request.resource.data.diff(resource.data)
                        .affectedKeys()
                        .hasOnly(['isHidden', 'hiddenByOwner', 'reportCount']));
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // REPORTS (بلاغات): الكل ينشئ | الأدمن يقرأ ويعدّل ويحذف
    // ──────────────────────────────────────────────
    match /reports/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BLOCKED USERS: الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /blocked_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BANNED USERS (نظام الحظر الجديد):
    // الكل يقرأ (عشان فحص الحظر عند تحميل الموقع) | الأدمن فقط يكتب
    // ──────────────────────────────────────────────
    match /banned_users/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // BAN ACCESS LOG (سجل محاولات الوصول المحظورة):
    // أي أحد ينشئ (يسجّل محاولة الدخول) | الأدمن يقرأ ويحذف
    // ──────────────────────────────────────────────
    match /ban_access_log/{id} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // DELIVERY AGENTS (المندوبين): الأدمن فقط
    // ──────────────────────────────────────────────
    match /delivery_agents/{id} {
      allow read, write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // DELIVERY RATINGS (تقييمات التوصيل): العميل يقرأ وينشئ | الأدمن يقرأ
    // ──────────────────────────────────────────────
    match /delivery_ratings/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // ADS (إعلانات منبثقة): الكل يقرأ | الأدمن يكتب
    // ──────────────────────────────────────────────
    match /ads/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // PUSH TOKENS: الكل ينشئ/يعدّل (تسجيل الجهاز)
    //              الأدمن يقرأ كل التوكنات
    // ──────────────────────────────────────────────
    match /push_tokens/{id} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // NOTIFICATIONS LOG: الأدمن فقط
    // ──────────────────────────────────────────────
    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // SUPPORT CHATS: الكل ينشئ ويكتب في محادثته | الأدمن يقرأ ويرد
    // ──────────────────────────────────────────────
    match /support_chats/{chatId} {
      allow read: if request.auth != null
                  || request.resource == null
                  || resource == null
                  || resource.data.deviceId == chatId;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // ABANDONED CARTS: العميل يحفظ/يقرأ/يحذف سلته بالـ deviceId
    // ──────────────────────────────────────────────
    match /abandoned_carts/{deviceId} {
      allow read, create, update, delete: if true;
    }

    // ──────────────────────────────────────────────
    // POS CUSTOMERS (كاشير — سجل العملاء): الأدمن فقط
    // ──────────────────────────────────────────────
    match /pos_customers/{id} {
      allow read, write: if request.auth != null;
    }

    // ──────────────────────────────────────────────
    // أي مجموعة أخرى: محظور تماماً (أمان افتراضي)
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
